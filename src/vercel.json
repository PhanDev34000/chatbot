{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/chatbot/browser"
      }
    }
  ],
  "build": {
    "env": {
      "ANTHROPIC_API_KEY": "@anthropic_api_key"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}